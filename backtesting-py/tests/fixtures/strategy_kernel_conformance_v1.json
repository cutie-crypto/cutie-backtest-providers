      "name": "rolling_extreme_min_with_gap",
      "primitive": "rolling_extreme",
      "params": {
        "window_bars": 2,
        "mode": "min"
      },
      "description": "ts=3600 is a genuine gap; both the frame at the gap itself and the following frame whose window still includes it are missing.",
      "input": [
        {
          "ts": 0,
