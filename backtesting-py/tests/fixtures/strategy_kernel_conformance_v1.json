          "value": "30"
        }
      ]
    },
    {
      "name": "rolling_quantile_single_sample_at_stream_start",
      "primitive": "rolling_quantile",
      "params": {
        "window_bars": 3,
        "quantile": "0.5",
        "min_periods": 1
      },
      "description": "f=1 at the very first timestamp of the stream (min_periods=1 accepts it): a single-sample window has no second order statistic to interpolate against, so R-7 returns that one sample directly rather than indexing x[1]. f=2 at the next frame exercises the ordinary n=2 interpolation.",
      "input": [
        {
          "ts": 0,
          "value": "42"
        },
        {
          "ts": 3600,
          "value": "50"
        }
      ],
      "expected": [
        {
          "ts": 0,
          "value": "42"
        },
        {
          "ts": 3600,
          "value": "46"
        }
      ]
    },
    {
      "name": "rolling_extreme_decimal128_rounding_tie_even_stays",
      "primitive": "rolling_extreme",
      "params": {
        "window_bars": 1,
        "mode": "max"
      },
      "description": "decimal128 ROUND_HALF_EVEN boundary: a single-element window's 'extreme' is the raw source value unchanged by min()/max() comparison, so it must still be rounded to 34 significant digits on output. Input has 35 significant digits with an exact tie at digit 35 ('...25'); digit 34 ('2') is already even, so banker's rounding keeps it (rounds toward even, i.e. down here).",
      "input": [
        {
          "ts": 0,
          "value": "1.2222222222222222222222222222222225"
        }
      ],
      "expected": [
        {
          "ts": 0,
          "value": "1.222222222222222222222222222222222"
        }
      ]
    },
    {
      "name": "rolling_extreme_decimal128_rounding_tie_odd_rounds_up",
      "primitive": "rolling_extreme",
      "params": {
        "window_bars": 1,
        "mode": "max"
      },
      "description": "Same exact-tie boundary as the sibling case, but digit 34 ('3') is odd, so ROUND_HALF_EVEN rounds up to the nearest even digit ('4') instead of down.",
      "input": [
        {
          "ts": 0,
          "value": "1.2222222222222222222222222222222235"
        }
      ],
      "expected": [
        {
          "ts": 0,
          "value": "1.222222222222222222222222222222224"
        }
      ]
    },
    {
      "name": "rolling_extreme_decimal128_rounding_more_than_half",
      "primitive": "rolling_extreme",
      "params": {
        "window_bars": 1,
        "mode": "max"
      },
      "description": "38 significant digits, not a tie (digits beyond position 35 are nonzero) -> rounds up regardless of digit 34's parity.",
      "input": [
        {
          "ts": 0,
          "value": "1.2345678901234567890123456789012345678"
        }
      ],
      "expected": [
        {
          "ts": 0,
          "value": "1.234567890123456789012345678901235"
        }
      ]
    },
    {
      "name": "rsi_wilder_seed_avg_loss_zero",
      "primitive": "rsi_wilder",
      "params": {
        "period": 2
      },
      "description": "Monotonically increasing prices: both seed deltas are gains, so avg_loss=0 at the seed and RSI=100 by the avg_loss==0 rule, independent of the alternating-delta case below.",
