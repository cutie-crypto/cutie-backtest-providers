{
  "schema": "cutie.strategy_kernel_conformance.v1",
  "source_of_truth": "SPEC §5.5/§7.3 (2026-07-17 增补, 62-2b Phase 1); Server/Connector/Provider share this fixture verbatim",
  "note": "All series use a fixed 1h (3600s) step starting at ts=0 unless a case overrides `interval`/`primary_interval`. `value: null` in `input` marks a genuine mid-stream gap (a timestamp the fetch reports but with no value) — distinct from a timestamp simply absent before the series' first entry, which is the stream-start boundary case. `expected: null` marks a frame the primitive must report missing (never a fabricated value).",
  "cases": [
    {
      "name": "rolling_quantile_min_periods_boundary_and_interpolation",
      "primitive": "rolling_quantile",
      "params": {
        "window_bars": 4,
        "quantile": "0.5",
        "min_periods": 3
      },
      "description": "f=1,2 < min_periods=3 -> missing; f=3 at the stream-start boundary (window_bars=4 not yet reached) uses R-7 with n=3; f=4 once the window is full uses n=4 with a fractional interpolation.",
      "input": [
        {
          "ts": 0,
          "value": "10"
        },
        {
          "ts": 3600,
          "value": "20"
        },
        {
          "ts": 7200,
          "value": "30"
        },
        {
          "ts": 10800,
          "value": "40"
        },
        {
          "ts": 14400,
          "value": "50"
        }
      ],
      "expected": [
        {
          "ts": 0,
          "value": null
        },
        {
          "ts": 3600,
          "value": null
        },
        {
          "ts": 7200,
          "value": "20"
        },
        {
          "ts": 10800,
          "value": "25"
        },
        {
          "ts": 14400,
          "value": "35"
        }
      ]
    },
    {
      "name": "rolling_quantile_gap_is_never_skipped",
      "primitive": "rolling_quantile",
      "params": {
        "window_bars": 3,
        "quantile": "0.5",
        "min_periods": 2
      },
      "description": "ts=3600's value is a genuine gap (present timestamp, null value). Every frame whose window still includes ts=3600 stays missing regardless of min_periods, until the window slides past it.",
      "input": [
        {
          "ts": 0,
          "value": "10"
        },
        {
          "ts": 3600,
          "value": null
        },
        {
          "ts": 7200,
          "value": "30"
        },
        {
          "ts": 10800,
          "value": "40"
        },
        {
          "ts": 14400,
          "value": "50"
        }
      ],
      "expected": [
        {
          "ts": 0,
          "value": null
        },
        {
          "ts": 3600,
          "value": null
        },
        {
          "ts": 7200,
          "value": null
        },
        {
          "ts": 10800,
          "value": null
        },
        {
          "ts": 14400,
          "value": "40"
        }
      ]
    },
    {
      "name": "rolling_extreme_max_and_min_no_leniency",
      "primitive": "rolling_extreme",
      "params": {
        "window_bars": 3,
        "mode": "max"
      },
      "description": "rolling_extreme never has min_periods leniency: f<window_bars is always missing, exactly like the frozen rolling_sum semantics.",
      "input": [
        {
          "ts": 0,
          "value": "5"
        },
        {
          "ts": 3600,
          "value": "9"
        },
        {
          "ts": 7200,
          "value": "3"
        },
        {
          "ts": 10800,
          "value": "3"
        },
        {
          "ts": 14400,
          "value": "3"
        },
        {
          "ts": 18000,
          "value": "8"
        },
        {
          "ts": 21600,
          "value": "1"
        }
      ],
      "expected": [
        {
          "ts": 0,
          "value": null
        },
        {
          "ts": 3600,
          "value": null
        },
        {
          "ts": 7200,
          "value": "9"
