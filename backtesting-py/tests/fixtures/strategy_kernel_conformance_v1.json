    {
      "name": "rsi_wilder_seed_at_fetch_window_start",
      "primitive": "rsi_wilder",
      "params": {
        "period": 2
      },
      "description": "Seed = simple average of the first 2 deltas measured from this series' own first entry (ts=0), never any hypothetical longer history — the seed here has avg_gain=avg_loss=1 (RS=1, RSI=50), distinct from the avg_loss=0 case above. Alternating +2/-2 deltas afterward keep every recursive step an exact decimal.",
      "input": [
        {
          "ts": 0,
          "value": "100"
        },
        {
          "ts": 3600,
          "value": "102"
        },
        {
          "ts": 7200,
          "value": "100"
